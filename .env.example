# 复制为 .env 并填写（.gitignore 已忽略 .env，勿提交密钥）
# load_config() 会通过 python-dotenv 从仓库根或当前工作目录加载 .env

# ── LLM（config/llm/providers.d/*.yaml 中的 api_key 使用下列变量） ──
DASHSCOPE_API_KEY=
MOONSHOT_API_KEY=
# Kimi Code（https://www.kimi.com/code/ 会员；endpoint 为 api.kimi.com/coding ，与 MOONSHOT 通用 key 可能不同）
KIMI_CODE_API_KEY=
# 上海交大 models.sjtu.edu.cn（见 https://chat.sjtu.edu.cn/docs ，需校内网络）
SJTU_MODELS_API_KEY=
# Google Gemini API（OpenAI 兼容，见 https://ai.google.dev/gemini-api/docs/openai ）
GEMINI_API_KEY=
# OpenAI 官方（config/llm/providers.d/openai_official.yaml）
OPENAI_API_KEY=
# DeepSeek 官方 API（OpenAI 兼容，见 https://api-docs.deepseek.com/zh-cn/ ）
DEEPSEEK_API_KEY=

# ── Canvas ──
CANVAS_API_KEY=
# CANVAS_BASE_URL=https://oc.sjtu.edu.cn/api/v1

# ── 飞书（config/config.yaml 中 app_id/app_secret 可留空，由此处覆盖） ──
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_AUTOMATION_CHAT_ID=

# ── 联网 / MCP ──
TAVILY_API_KEY=
